# Development environment variables
# 默认已与仓库端口策略一致：前端 dev 15173、后端 18080（勿再用 5173 / 8000）
# API 使用 127.0.0.1 而非 localhost：在 macOS 上 localhost 常优先解析为 ::1，
# 若本机另有进程占用 18080（IPv4）与 Docker 映射（IPv6）并存，走 ::1 可能得到 ERR_CONNECTION_RESET。
VITE_APP_TITLE=SuperInsight
VITE_API_BASE_URL=http://127.0.0.1:18080
VITE_APP_ENV=development
