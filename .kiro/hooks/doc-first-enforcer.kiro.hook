{
  "enabled": true,
  "name": "文档优先提醒",
  "description": "修改代码时提醒更新文档",
  "version": "2.0.0",
  "when": {
    "type": "fileEdited",
    "patterns": ["src/**/*.py", "frontend/src/**/*.tsx", "frontend/src/**/*.ts"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Code modified. Update docs first: requirements.md, design.md, tasks.md, CHANGELOG.md"
  }
}