# SuperInsight - 本地生产验证环境
# 用于 docker-compose.prod.yml，模拟 Sealos 部署行为
# 复制此文件并填入实际值

# =============================================================================
# Database（使用 compose 内置 PostgreSQL）
# =============================================================================
DATABASE_URL=postgresql://superinsight:password@postgres:5432/superinsight
POSTGRES_USER=superinsight
POSTGRES_PASSWORD=password
POSTGRES_DB=superinsight

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Label Studio
# =============================================================================
LABEL_STUDIO_URL=http://label-studio:8080
LABEL_STUDIO_API_TOKEN=your-token-here
LABEL_STUDIO_SSO_ENABLED=true
LABEL_STUDIO_SSO_EMAIL=admin@example.com
LABEL_STUDIO_USERNAME=admin@example.com
LABEL_STUDIO_PASSWORD=admin

# =============================================================================
# Argilla
# =============================================================================
ARGILLA_URL=http://argilla:6900

# =============================================================================
# LLM（本地用 Ollama，Sealos 用外部 API）
# =============================================================================
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://ollama:11434/v1
OPENAI_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://ollama:11434

# =============================================================================
# Security
# =============================================================================
JWT_SECRET_KEY=your-secret-key-change-in-production
LLM_ENCRYPTION_KEY=your-encryption-key-change-in-production
CORS_ORIGINS=http://localhost,http://localhost:80

# =============================================================================
# Application
# =============================================================================
APP_ENV=production
