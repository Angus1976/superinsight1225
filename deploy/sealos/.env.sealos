# SuperInsight Sealos 部署环境变量
# ⚠️ 标注 <TODO> 的需要你手动填写
# ⚠️ Sealos 内网地址必须用完整 FQDN（.svc.cluster.local），否则 DNS 解析失败
#
# 📌 应用命名约定（固定名称，避免重建后 FQDN 变化）：
#   superinsight-es       → Elasticsearch
#   superinsight-argilla  → Argilla
#   superinsight-ls       → Label Studio
#   superinsight-backend  → Backend (FastAPI)
#   superinsight-celery   → Celery Worker
#   superinsight-frontend → Frontend (Nginx)
# FQDN 格式：<应用名>.ns-<namespace>.svc.cluster.local

# ============ 应用 ============
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# ============ 数据库（Sealos 托管 PostgreSQL 15） ============
DATABASE_URL=postgresql+psycopg2://postgres:pqlhjv6k@superdata1-postgresql.ns-7a6zs8pw.svc.cluster.local:5432/superinsight

# ============ Redis（Sealos 托管 Redis 7） ============
REDIS_URL=redis://default:rH8v2L9v19@superdata11-redis-redis.ns-7a6zs8pw.svc.cluster.local:6379/0

# ============ Elasticsearch ============
# ⚠️ 使用固定应用名 superinsight-es，避免重建后地址变化
ELASTICSEARCH_URL=http://superinsight-es-yhmzavzicdqj.ns-7a6zs8pw.svc.cluster.local:9200

# ============ LLM（外部 API，不用 Ollama） ============
# 方案 A: DeepSeek（推荐，便宜）
OPENAI_API_KEY=<TODO:your-deepseek-api-key>
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# 方案 B: 通义千问（取消注释切换）
# OPENAI_API_KEY=<TODO:your-dashscope-api-key>
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-plus

LLM_ENCRYPTION_KEY=<TODO:generate-a-random-32-char-string>

# ============ Label Studio ============
# SSO 模式：后端通过 /api/sso/token 生成 JWT，iframe 用 ?token=xxx 自动登录
# 需要 label-studio-sso 包（Dockerfile.labelstudio 已包含）
# API Token 通过 Django shell 生成：Token.objects.create(user=admin_user)
LABEL_STUDIO_URL=http://superinsight-ls-bdixpnpqlzbm.ns-7a6zs8pw.svc.cluster.local:8080
LABEL_STUDIO_API_TOKEN=21d44d803c6976e25fbd2b0a71820b639afac61f
LABEL_STUDIO_SSO_ENABLED=true
LABEL_STUDIO_SSO_EMAIL=admin@superinsight.local

# ============ Argilla ============
ARGILLA_URL=http://superinsight-argilla-fhgrcouznycf.ns-7a6zs8pw.svc.cluster.local:6900
ARGILLA_API_KEY=argilla-superinsight-api-key-2026

# ============ 安全 ============
JWT_SECRET_KEY=<TODO:generate-a-random-64-char-string>
CORS_ORIGINS=https://<TODO:your-sealos-frontend-domain>
