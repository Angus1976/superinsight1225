# SuperInsight Sealos 部署环境变量
# 使用前请替换所有 <...> 占位符

# ============ 应用 ============
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# ============ 数据库（Sealos 托管 PostgreSQL） ============
# 在 Sealos 数据库面板创建后，填入连接串
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/superinsight

# ============ Redis（Sealos 托管 Redis） ============
REDIS_URL=redis://:<password>@<host>:6379/0

# ============ LLM（外部 API，不用 Ollama） ============
# 方案 A: DeepSeek（推荐，便宜）
OPENAI_API_KEY=<your-deepseek-api-key>
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# 方案 B: 通义千问
# OPENAI_API_KEY=<your-dashscope-api-key>
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-plus

LLM_ENCRYPTION_KEY=<generate-a-random-32-char-string>

# ============ Label Studio ============
LABEL_STUDIO_URL=http://superinsight-label-studio:8080
LABEL_STUDIO_USERNAME=admin@superinsight.local
LABEL_STUDIO_PASSWORD=<your-label-studio-password>

# ============ Argilla ============
ARGILLA_URL=http://superinsight-argilla:6900
ARGILLA_API_KEY=<your-argilla-api-key>

# ============ Elasticsearch（Argilla 依赖） ============
ARGILLA_ELASTICSEARCH=http://superinsight-elasticsearch:9200

# ============ 安全 ============
JWT_SECRET_KEY=<generate-a-random-64-char-string>
CORS_ORIGINS=https://<your-sealos-domain>
