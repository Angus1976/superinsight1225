# Test Environment Configuration
# This file is used for running tests

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=SuperInsight-Test
APP_ENV=test
APP_DEBUG=false
APP_HOST=localhost
APP_PORT=8001

# =============================================================================
# Test Database Configuration
# =============================================================================
# Use in-memory SQLite for fast unit tests
DATABASE_URL=sqlite:///:memory:
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false

# PostgreSQL test database configuration (for integration tests)
# Using Docker PostgreSQL on port 5432
TEST_POSTGRES_HOST=localhost
TEST_POSTGRES_PORT=5432
TEST_POSTGRES_USER=superinsight_test
TEST_POSTGRES_PASSWORD=test_password
TEST_POSTGRES_DB=superinsight_test

# Connection pool settings for test database
TEST_DATABASE_POOL_SIZE=5
TEST_DATABASE_MAX_OVERFLOW=10
TEST_DATABASE_POOL_TIMEOUT=30
TEST_DATABASE_POOL_RECYCLE=3600

# =============================================================================
# Test Redis Configuration
# =============================================================================
# Use separate Redis port and database for test isolation
REDIS_URL=redis://localhost:6380/15
REDIS_MAX_CONNECTIONS=10

# =============================================================================
# Test LLM Configuration
# =============================================================================
LLM_HEALTH_CHECK_INTERVAL=300
LLM_MAX_FAILURES=5
OPENAI_API_KEY=test-api-key-not-real
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Test AI Annotation Settings
# =============================================================================
ANNOTATION_BATCH_SIZE=10
ANNOTATION_MAX_CONCURRENCY=5
ANNOTATION_BATCH_TIMEOUT_SECONDS=60

MODEL_CACHE_STRATEGY=lru
MODEL_CACHE_MAX_SIZE_MB=100
MODEL_CACHE_TTL_SECONDS=300

RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_BURST_SIZE=100

ANNOTATION_CONFIDENCE_THRESHOLD=0.7
ANNOTATION_REVIEW_THRESHOLD=0.5
ANNOTATION_AUTO_ACCEPT_THRESHOLD=0.95

# =============================================================================
# Test Label Studio Configuration
# =============================================================================
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_USERNAME=test-admin
LABEL_STUDIO_PASSWORD=test-password
LABEL_STUDIO_API_KEY=test-api-key

# =============================================================================
# Test Security
# =============================================================================
JWT_SECRET_KEY=test-secret-key-do-not-use-in-production-12345678
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Data Transfer / Lifecycle Settings
# =============================================================================
# No config file override in tests — use built-in defaults
PERMISSION_MATRIX_CONFIG_FILE=
# Lower threshold for easier testing of batch approval logic
PERMISSION_BATCH_THRESHOLD=100
# Short timeout so expiry tests run quickly (2 hours)
APPROVAL_TIMEOUT_HOURS=2

# =============================================================================
# Test Coverage Configuration
# =============================================================================
COVERAGE_THRESHOLD=80
COVERAGE_REPORT_HTML=true
COVERAGE_REPORT_JSON=true
