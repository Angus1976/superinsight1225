# ============ 应用 ============
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# ============ 数据库（Sealos 托管 PostgreSQL 15） ============
DATABASE_URL=postgresql://postgres:pqlhjv6k@superdata1-postgresql.ns-7a6zs8pw.svc:5432/superinsight

# ============ Redis（Sealos 托管 Redis 7） ============
REDIS_URL=redis://default:rH8v2L9v19@superdata11-redis-redis.ns-7a6zs8pw.svc:6379/0

# ============ LLM（外部 API，不用 Ollama） ============
