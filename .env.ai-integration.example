# =============================================================================
# AI Application Integration Environment Variables
# =============================================================================
# Copy this file to .env and configure the values for your environment
#
# Usage:
#   cp .env.ai-integration.example .env
#   # Edit .env with your values
#   docker-compose -f docker-compose.yml -f docker-compose.ai-integration.yml up
# =============================================================================

# -----------------------------------------------------------------------------
# SuperInsight API Configuration
# -----------------------------------------------------------------------------
# API key for OpenClaw to authenticate with SuperInsight
# Generate this through the SuperInsight admin interface
OPENCLAW_API_KEY=your-api-key-here

# Tenant ID for multi-tenant isolation
# Each OpenClaw instance is associated with exactly one tenant
TENANT_ID=your-tenant-id-here

# -----------------------------------------------------------------------------
# OpenClaw Gateway Configuration
# -----------------------------------------------------------------------------
# Port for OpenClaw gateway (default: 3000)
# GATEWAY_PORT=3000

# Log level for OpenClaw services (debug, info, warn, error)
OPENCLAW_LOG_LEVEL=info

# Node environment (development, production)
NODE_ENV=production

# -----------------------------------------------------------------------------
# OpenClaw Agent Configuration
# -----------------------------------------------------------------------------
# Agent display name
OPENCLAW_AGENT_NAME=SuperInsight Assistant

# Agent description
OPENCLAW_AGENT_DESCRIPTION=AI assistant for governed data access

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# LLM provider (ollama, openai, anthropic, groq, azure, qwen, zhipu, baidu, hunyuan)
OPENCLAW_LLM_PROVIDER=ollama

# LLM model name
OPENCLAW_LLM_MODEL=llama2

# LLM API URL (for Ollama or custom endpoints)
OPENCLAW_LLM_API_URL=http://ollama:11434

# LLM API key (for cloud providers)
OPENCLAW_LLM_API_KEY=

# -----------------------------------------------------------------------------
# Language Configuration
# -----------------------------------------------------------------------------
# System prompt for language-specific behavior (injected by deployment script)
OPENCLAW_SYSTEM_PROMPT=

# User language preference (zh-CN, en-US)
OPENCLAW_USER_LANGUAGE=zh-CN

# Locale for formatting (zh-CN, en-US)
OPENCLAW_LOCALE=zh-CN

# -----------------------------------------------------------------------------
# Channel Configuration (Optional)
# -----------------------------------------------------------------------------
# Configure specific channels as needed
# These are typically managed through the SuperInsight admin interface

# WhatsApp
# OPENCLAW_WHATSAPP_ENABLED=false
# OPENCLAW_WHATSAPP_PHONE_NUMBER=
# OPENCLAW_WHATSAPP_API_KEY=

# Telegram
# OPENCLAW_TELEGRAM_ENABLED=false
# OPENCLAW_TELEGRAM_BOT_TOKEN=

# Slack
# OPENCLAW_SLACK_ENABLED=false
# OPENCLAW_SLACK_BOT_TOKEN=
# OPENCLAW_SLACK_SIGNING_SECRET=

# Discord
# OPENCLAW_DISCORD_ENABLED=false
# OPENCLAW_DISCORD_BOT_TOKEN=
